# =============================================================================
# Mari (HUB Obra 10+) — copie para .env e preencha. Não commite segredos reais.
# =============================================================================

# -----------------------------------------------------------------------------
# Modelo (Mistral / Agno)
# -----------------------------------------------------------------------------
MISTRAL_API_KEY=
# Agno (chat): mistral:<model_id>. Visão: pixtral-large-latest ou outro com imagem na API.
# MARIA_MODEL=mistral:pixtral-large-latest
MARIA_MODEL=mistral:mistral-small-latest
#
# STT — transcrição de voz WhatsApp (Mistral audio transcriptions; ex. Studio "fala → texto"):
# Usa a mesma MISTRAL_API_KEY. Desliga com MARIA_STT_ENABLED=0.
# MARIA_STT_MODEL=voxtral-mini-latest
# MARIA_STT_LANGUAGE=pt
# MARIA_STT_MAX_BYTES=26214400
# MARIA_STT_TIMESTAMP_SEGMENTS=1
# Opcional: prefixo injetado antes do texto transcrito para o modelo (markdown curto).
# MARIA_STT_CONTEXT_PREFIX=[Mensagem de voz do cliente, transcrita automaticamente.]

# -----------------------------------------------------------------------------
# AgentOS (Studio / API Bearer)
# -----------------------------------------------------------------------------
# Se definido, rotas como POST /agents/.../runs exigem: Authorization: Bearer <valor>
# OS_SECURITY_KEY=

# -----------------------------------------------------------------------------
# Base de dados Agno (sessões + memórias do utilizador)
# -----------------------------------------------------------------------------
# Produção (Render, etc.): use Postgres — SQLite no container não persiste entre deploys.
# DATABASE_URL=postgresql://postgres:SENHA@db.xxxx.supabase.co:5432/postgres?sslmode=require
# Alias aceite pelo código:
# SUPABASE_DATABASE_URL=

# -----------------------------------------------------------------------------
# Supabase (leads, turnos, Storage)
# -----------------------------------------------------------------------------
# SQL a correr no projeto: supabase/sql/leads.sql, mari_conversation_turns.sql, mari_lead_media.sql, mari_imoveis.sql
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Bucket Storage para anexos (criar no Dashboard com este nome ou ajustar env abaixo).
MARIA_STORAGE_BUCKET=maria-lead-media
# Limite de bytes ao descarregar URL para registar_midia_url_no_lead (default ~15MB).
# MARIA_MEDIA_MAX_BYTES=15728640

# -----------------------------------------------------------------------------
# UAZAPI — WhatsApp
# -----------------------------------------------------------------------------
UAZAPI_BASE_URL=https://sua-instancia.uazapi.com
UAZAPI_INSTANCE_TOKEN=
# Opcional recomendado em produção: mesmo valor no header do webhook (ver painel UAZAPI).
# UAZAPI_WEBHOOK_SECRET=
# Responder em grupos (default: off).
# UAZAPI_ALLOW_GROUPS=1
# Menus com botões/lista na resposta do webhook (bloco <<<MARIA_MENU_JSON>>>).
# MARIA_INTERACTIVE_MENU=0

# -----------------------------------------------------------------------------
# Webhook — multimodal e debug
# -----------------------------------------------------------------------------
# Envia URLs de imagem ao agent.arun(images=...). Desliga se o modelo não suportar visão.
# Render: use 1 para WhatsApp com fotos + modelo Pixtral (ou outro Mistral com visão).
MARIA_MULTIMODAL_VISION=1
MARIA_MULTIMODAL_MAX_IMAGES=4
# Limite ao descarregar imagem/documento no webhook (UAZAPI message/download + URLs).
# MARIA_MAX_INBOUND_MEDIA_BYTES=12582912
# MARIA_LOG_WEBHOOK_BODY=1
# Logs linha a linha no stderr (Render/agregadores sem TTY) — mais fácil de ler que Rich.
# MARIA_PLAIN_LOGS=1
#
# Fotos via UAZAPI message/download → Supabase Storage + mari_lead_media (default ligado; não precisa de URL).
# MARIA_PERSIST_UAZAPI_DOWNLOAD_MEDIA=0
# MARIA_INBOUND_DOWNLOAD_MEDIA_TIPO_LEAD=proprietario
# MARIA_ATTACH_UAZAPI_MEDIA_TO_LATEST_IMOVEL=1

MARIA_COMPRESS_TOOL_RESULTS=1
# MARIA_COMPRESSION_TOOL_LIMIT=3
# MARIA_COMPRESSION_TOKEN_LIMIT=8000
# MARIA_COMPRESSION_MODEL=mistral:mistral-small-latest

# -----------------------------------------------------------------------------
# Admin API + CORS
# -----------------------------------------------------------------------------
MARIA_ADMIN_API_KEY=mari_exemplo_TROCAR_por_segredo_longo
# Origens permitidas (vírgula). Produção: URL do teu front.
MARIA_CORS_ORIGINS=http://localhost:5173

# -----------------------------------------------------------------------------
# OpenAPI / docs (AgentOS; alguns hosts definem globalmente)
# -----------------------------------------------------------------------------
# DOCS_ENABLED=true

# -----------------------------------------------------------------------------
# Servidor local / Docker (Render injeta PORT automaticamente)
# -----------------------------------------------------------------------------
# PORT=8000

# -----------------------------------------------------------------------------
# Scripts opcionais (scripts/smoke_chat.py, scripts/list_user_memories.py)
# -----------------------------------------------------------------------------
# SMOKE_USER_ID=smoke-test-local
# SMOKE_SESSION_ID=smoke-session-1
# SMOKE_MESSAGE=Olá Mari
# LIST_MEMORY_USER_ID=5511999999999

# -----------------------------------------------------------------------------
# Logging (maria_logging.py)
# -----------------------------------------------------------------------------
# FORCE_COLOR=1
# LOG_WIDTH=120
