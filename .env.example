# Mistral — Agno aceita modelo como string "mistral:<model_id>"
MISTRAL_API_KEY=

# Opcional (padrão: mistral:mistral-small-latest)
# Para analisar imagens recebidas no WhatsApp, usa um modelo com visão (ex.: mistral com API que aceite imagens).
MARIA_MODEL=mistral:mistral-small-latest

# Multimodal (webhook → Agno): envia URLs de imagem ao ``arun(images=...)``. Desliga se o modelo não suportar visão.
# MARIA_MULTIMODAL_VISION=0
# MARIA_MULTIMODAL_MAX_IMAGES=4

# Bucket Supabase Storage para anexos de leads (criar no Dashboard; SQL: supabase/sql/mari_lead_media.sql).
# MARIA_STORAGE_BUCKET=maria-lead-media
# MARIA_MEDIA_MAX_BYTES=15728640

# Compressão de resultados de tools (Agno) — poupa contexto quando há JSON grande (UAZAPI, contexto_lead_por_telefone).
# MARIA_COMPRESS_TOOL_RESULTS=0   # desliga
# MARIA_COMPRESSION_TOOL_LIMIT=3  # após N tool results sem comprimir, resume (2–20)
# MARIA_COMPRESSION_TOKEN_LIMIT=8000  # opcional: também comprimir por limite de tokens
# MARIA_COMPRESSION_MODEL=mistral:mistral-small-latest  # opcional: modelo só para compressão (senão usa o do agente)

# AgentOS: se definires, rotas como POST /agents/.../runs exigem:
#   Authorization: Bearer <valor>
# No Swagger: Authorize → HTTP Bearer → mesmo valor.
# Para testar sem auth localmente, não definir esta variável.
# OS_SECURITY_KEY=

# Docs OpenAPI (por defeito true). Se algum env global desativar:
# DOCS_ENABLED=true

# Supabase — executar no SQL Editor (mesmo projecto):
#   supabase/sql/leads.sql
#   supabase/sql/mari_conversation_turns.sql  (histórico WhatsApp cliente ↔ Mari)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Painel / API admin: inventa um segredo longo (não commits o valor real aqui).
MARIA_ADMIN_API_KEY=mari_exemplo_TROCAR_por_segredo_longo

# Origens CORS para o browser falar com a API (URL do teu dashboard, vírgula se forem várias).
MARIA_CORS_ORIGINS=http://localhost:5173

# Opcional — JSON completo (truncado) nos logs de cada POST /webhooks/uazapi (só em debug).
# MARIA_LOG_WEBHOOK_BODY=1

# Opcional — sessões + memórias Agno em Postgres (URI do Supabase; Agno cria tabelas incl. memórias).
# Sem DATABASE_URL as memórias ficam em ./agno.db (SQLite local).
# DATABASE_URL=postgresql://postgres:...@db.xxxx.supabase.co:5432/postgres?sslmode=require
